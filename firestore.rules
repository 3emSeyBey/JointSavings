rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userHouseholdId() {
      let p = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(p) ? get(p).data.householdId : null;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /households/{hid}/data/{document=**} {
      allow read, write: if request.auth != null && userHouseholdId() == hid;
    }

    match /aiRate/{userId} {
      allow read, write: if false;
    }

    match /artifacts/{appId}/public/data/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
