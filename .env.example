# Firebase CLI: copy .firebaserc.example to .firebaserc and set "default" to the same
# project id as VITE_FIREBASE_PROJECT_ID (or run: npm run firebase:use)
# cp .firebaserc.example .firebaserc

# Firebase (required)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional app id (legacy artifact path for migration only)
VITE_APP_ID=joint-savings-app

# Household partition for Firestore data (default: default)
VITE_HOUSEHOLD_ID=default

# AI coach: direct Gemini from the browser (default). Get a key at https://aistudio.google.com/apikey
# VITE_GEMINI_API_KEY=

# Only if you use the generateAI Cloud Function proxy (no VITE_GEMINI_API_KEY):
# VITE_FUNCTIONS_REGION=us-central1
# Server-side (Firebase secret GEMINI_API_KEY), not Vite — see README.

# Feature flags (optional, Wave 3 / H-006)
# VITE_FLAG_OPEN_FINANCE=true
# VITE_FLAG_VOICE_COACH=true
# VITE_FLAG_SOCIAL=true
